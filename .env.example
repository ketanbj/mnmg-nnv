RAY_IMAGE=rayproject/ray:2.53.0-py311

RAY_PORT=6379
# Leave empty to auto-pick from SLURM_JOB_ID (recommended), or set a fixed free port.
RAY_CLIENT_PORT=
RAY_DASHBOARD_PORT=8265

RAY_HEAD_CPUS=1
RAY_HEAD_OBJECT_STORE_MEMORY=134217728
RAY_HEAD_SHM_SIZE=1gb

RAY_WORKER_CPUS=4
RAY_WORKER_OBJECT_STORE_MEMORY=1073741824
RAY_WORKER_SHM_SIZE=2gb

# Docker: number of ray-worker replicas for `make docker up`.
WORKER_REPLICAS=1

# Optional: run Slurm commands via SSH hop to login node
SLURM_LOGIN=
SLURM_REMOTE_DIR=
# Optional: override auto-generated per-submit Slurm job name
# SLURM_JOB_NAME=ray-exp-01
# Optional: auto-sync local files to SLURM_REMOTE_DIR before remote make
SLURM_SYNC=1
# Optional: customize synced files for SSH Slurm flow
SLURM_SYNC_FILES=Makefile scripts/slurm/ray_cluster.sbatch .env

# Static IP-based Ray cluster (make cluster up|down)
CLUSTER_HOSTS_FILE=conf/cluster_hosts.conf
# CLUSTER_STATE_FILE=.ray-cluster-hosts
# CLUSTER_SSH=ssh

# Optional Slurm runtime overrides (absolute or PROJECT_ROOT-relative)
VENV_ACTIVATE=.venv/bin/activate
# UV_BIN=uv
# PROJECT_ROOT=
# ENTRYPOINT=abcrown.py
# ENTRYPOINT_ARGS=--disable_hugetensor_allocator --batch_size 256 --no_auto_enlarge_batch_size --config /storage/project/r-jyoung9-1/shared/nnv/exp_configs/alpha-beta-CROWN-performance-study/cifar_100.yaml --select_instance 66
# Optional:
# ENTRYPOINT_CMD=abcrown.py --disable_hugetensor_allocator --batch_size 256 --no_auto_enlarge_batch_size --config /storage/project/r-jyoung9-1/shared/nnv/exp_configs/alpha-beta-CROWN-performance-study/cifar_100.yaml --select_instance 66
# ENTRYPOINT_CMD is automatically executed via uv run by the sbatch script.
# Equivalent runtime command: uv run abcrown.py --disable_hugetensor_allocator --batch_size 256 --no_auto_enlarge_batch_size --config /storage/project/r-jyoung9-1/shared/nnv/exp_configs/alpha-beta-CROWN-performance-study/cifar_100.yaml --select_instance 66
# IMPORTANT: do not wrap ENTRYPOINT_ARGS or ENTRYPOINT_CMD in quotes.
# Use: ENTRYPOINT_ARGS=--flag value  (not ENTRYPOINT_ARGS="--flag value")
# If ENTRYPOINT_CMD is set, ENTRYPOINT/ENTRYPOINT_ARGS are ignored.
# RAY_LOG_ARCHIVE_DIR=logs/ray-slurm  # relative to SLURM_REMOTE_DIR (submit dir)
